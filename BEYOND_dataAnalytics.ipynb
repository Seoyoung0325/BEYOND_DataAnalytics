        "model.fit(\n",
        "    X_train, y_train,\n",
        "    eval_set=[(X_test, y_test)],\n",
        "    verbose=50\n",
        ")\n",
        "\n",
        "print(f'\\n 최적 트리 수: {model.best_iteration}')"
